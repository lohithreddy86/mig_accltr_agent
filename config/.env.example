# =============================================================================
# Environment template for SQL Migration Accelerator
# Copy this file to config/.env and fill in real values.
# config/.env is gitignored — never commit real secrets.
# =============================================================================

# --- LLM provider -----------------------------------------------------------
# Pick ONE of the routing modes below.

# Mode 1: Direct Anthropic (V1 default — see config/config.yaml `llm.api_key_env`)
ANTHROPIC_API_KEY=

# Mode 2: Enterprise LiteLLM proxy
# LLM_API_BASE=https://your-proxy.example/v1
# LLM_API_KEY=sk-your-proxy-token

# Mode 3: Direct Gemini
# GEMINI_API_KEY=

# --- Trino MCP server -------------------------------------------------------
TRINO_MCP_SERVER_URL=http://localhost:8000/mcp
TRINO_ADMIN_URL=http://localhost:8080
TRINO_ADMIN_USER=admin
